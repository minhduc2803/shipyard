# Harness configuration (non-secret). Sourced by bin/_common.sh.
# Override any value by exporting it before invoking a harness script.

HARNESS_ROOT="${HARNESS_ROOT:-$HOME/clinical/harness}"
LANES_ROOT="${LANES_ROOT:-$HOME/clinical}"             # lane clones: $LANES_ROOT/laneN
SOURCE_REPO="${SOURCE_REPO:-$HOME/clinical/stack-clinical}"   # local repo to clone from (fast) + compose file
ORIGIN_URL="${ORIGIN_URL:-}"                            # GitHub remote for lane clones; empty -> derived from SOURCE_REPO's origin in lane-bootstrap
PROFILE="${PROFILE:-clinical}"                          # active profile: profiles/<PROFILE>/ (stack hooks + config)

# Shared services (one set for all lanes)
PG_HOST="${PG_HOST:-127.0.0.1}"
PG_PORT="${PG_PORT:-5433}"
PG_USER="${PG_USER:-postgres}"
PG_PASS="${PG_PASS:-postgres}"
REDIS_HOST="${REDIS_HOST:-127.0.0.1}"
REDIS_PORT="${REDIS_PORT:-6379}"

# Per-lane derivations
DB_PREFIX="${DB_PREFIX:-edc_clinical_l}"               # -> edc_clinical_l1
API_BASE_PORT="${API_BASE_PORT:-8000}"                 # lane N -> 8000+N
FE_BASE_PORT="${FE_BASE_PORT:-3000}"                   # lane N -> 3000+N
WORKER_QUEUES="${WORKER_QUEUES:-default,sql_generation,embedding,summary,entities}"

COMPOSE_FILE="${COMPOSE_FILE:-$SOURCE_REPO/backend/docker-compose.yml}"

# Secrets (real values live in config/secrets.env, gitignored)
if [ -f "$HARNESS_ROOT/config/secrets.env" ]; then
  # shellcheck disable=SC1091
  source "$HARNESS_ROOT/config/secrets.env"
fi
SEED_USER_PASSWORD="${SEED_USER_PASSWORD:-changeme}"
SEED_USER_EMAIL="${SEED_USER_EMAIL:-acme_admin@localadmin.com}"
